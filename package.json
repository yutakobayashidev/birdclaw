{
	"name": "birdclaw",
	"version": "0.4.0",
	"description": "Local Twitter memory in SQLite for archives, DMs, likes, bookmarks, and moderation",
	"homepage": "https://github.com/steipete/birdclaw#readme",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/steipete/birdclaw.git"
	},
	"bin": {
		"birdclaw": "bin/birdclaw.mjs"
	},
	"files": [
		"bin/",
		"src/",
		"!src/**/*.test.ts",
		"!src/**/*.test.tsx",
		"!src/test/",
		"public/",
		"CHANGELOG.md",
		"LICENSE",
		"README.md",
		"package.json",
		"playwright.config.ts",
		"pnpm-lock.yaml",
		"tsconfig.json",
		"vite.config.ts"
	],
	"type": "module",
	"imports": {
		"#/*": "./src/*"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"dev": "vite dev --port 3000",
		"build": "vite build",
		"preview": "vite preview",
		"test": "env -u NODE_OPTIONS node ./scripts/run-vitest.mjs run",
		"coverage": "env -u NODE_OPTIONS node ./scripts/run-vitest.mjs run --coverage",
		"e2e": "playwright test",
		"typecheck": "tsgo --noEmit",
		"format": "oxfmt --write src scripts playwright vite.config.ts vitest.config.ts playwright.config.ts",
		"format:check": "oxfmt --check src scripts playwright vite.config.ts vitest.config.ts playwright.config.ts",
		"lint": "oxlint --import-plugin --node-plugin --vitest-plugin --deny-warnings -A require-mock-type-parameters -A no-control-regex src scripts playwright vite.config.ts vitest.config.ts playwright.config.ts",
		"check": "pnpm run format:check && pnpm run lint",
		"cli": "tsx src/cli.ts",
		"docs:site": "node scripts/build-docs-site.mjs"
	},
	"dependencies": {
		"@steipete/sweet-cookie": "^0.2.0",
		"@tailwindcss/vite": "^4.2.4",
		"@tanstack/devtools-vite": "0.6.0",
		"@tanstack/react-devtools": "0.10.2",
		"@tanstack/react-router": "1.169.1",
		"@tanstack/react-router-devtools": "1.166.13",
		"@tanstack/react-router-ssr-query": "1.166.12",
		"@tanstack/react-start": "1.167.61",
		"@tanstack/router-plugin": "^1.167.32",
		"@vitejs/plugin-react": "^6.0.1",
		"commander": "^14.0.3",
		"kysely": "^0.28.17",
		"lucide-react": "^1.14.0",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"tailwindcss": "^4.2.4",
		"tsx": "^4.21.0",
		"vite": "^8.0.10",
		"zod": "^4.4.2"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@tailwindcss/typography": "^0.5.19",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "7.0.0-dev.20260505.1",
		"@vitest/coverage-v8": "^4.1.5",
		"jsdom": "^29.1.1",
		"oxfmt": "^0.47.0",
		"oxlint": "^1.62.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"engines": {
		"node": ">=25.8.1 <27"
	},
	"packageManager": "pnpm@10.31.0",
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"lightningcss"
		]
	}
}
